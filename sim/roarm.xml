<mujoco model="roarm_m2s">
  <compiler angle="radian" meshdir="meshes"/>

  <option gravity="0 0 -9.81" timestep="0.002" integrator="implicitfast"/>

  <default>
    <joint damping="1.0" armature="0.05"/>
    <geom condim="4" friction="0.8 0.02 0.01"/>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.9 0.9 0.9" rgb2="0.7 0.7 0.7" width="512" height="512"/>
    <material name="grid_mat" texture="grid" texrepeat="8 8" texuniform="true"/>
    <material name="target_red" rgba="0.9 0.2 0.2 1"/>
    <material name="table_brown" rgba="0.55 0.35 0.2 1"/>

    <mesh name="base_link" content_type="model/stl" file="base_link.STL"/>
    <mesh name="link1" content_type="model/stl" file="link1.STL"/>
    <mesh name="link2" content_type="model/stl" file="link2.STL"/>
    <mesh name="link3" content_type="model/stl" file="link3.STL"/>
    <mesh name="gripper_link" content_type="model/stl" file="gripper_link.STL"/>
  </asset>

  <worldbody>
    <!-- Scene -->
    <geom name="ground" type="plane" size="1 1 0.01" material="grid_mat"/>
    <light name="spotlight" pos="0.0 0.0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3"/>
    <camera name="esp_cam" pos="-0.05 0.0 0.38" xyaxes="0 -1 0 -0.15 0 1" fovy="70"/>
    <camera name="side_cam" pos="0.0 -0.6 0.6" xyaxes="1 0 0 0 0.7 0.7" fovy="60"/>

    <body name="table" pos="0 0 0.35">
      <geom name="tabletop" type="box" size="0.3 0.3 0.01" material="table_brown" mass="5.0"/>
      <geom name="leg1" type="cylinder" fromto="-0.25 -0.25 -0.35  -0.25 -0.25 -0.01" size="0.02" material="table_brown"/>
      <geom name="leg2" type="cylinder" fromto=" 0.25 -0.25 -0.35   0.25 -0.25 -0.01" size="0.02" material="table_brown"/>
      <geom name="leg3" type="cylinder" fromto="-0.25  0.25 -0.35  -0.25  0.25 -0.01" size="0.02" material="table_brown"/>
      <geom name="leg4" type="cylinder" fromto=" 0.25  0.25 -0.35   0.25  0.25 -0.01" size="0.02" material="table_brown"/>
    </body>

    <body name="target_block" pos="0.15 0.0 0.37">
      <freejoint name="target_joint"/>
      <geom name="target" type="box" size="0.015 0.015 0.015" material="target_red" mass="0.02"/>
    </body>

    <!-- Arm (from MuJoCo URDF conversion, mounted on table) -->
    <body name="base_link" pos="0 0 0.36">
      <geom type="mesh" rgba="0.752941 0.752941 0.752941 1" mesh="base_link" contype="0" conaffinity="0"/>
      <body name="link1" pos="0.01 0 0.123059">
        <inertial pos="-3.1156e-12 9.7024e-06 -0.0146667" quat="0.707433 0.70678 0 0" mass="0.0928888" diaginertia="6.09211e-05 4.88051e-05 2.53493e-05"/>
        <joint name="base" pos="0 0 0" axis="0 0 -1" range="-3.1416 3.1416"/>
        <geom type="mesh" rgba="0.752941 0.752941 0.752941 1" mesh="link1" contype="0" conaffinity="0"/>
        <body name="link2" quat="0.5 -0.5 -0.5 -0.5">
          <inertial pos="0.122021 6.61338e-05 -9.50311e-05" quat="0.498128 0.497925 0.50206 0.501871" mass="0.0895817" diaginertia="0.00035039 0.000333057 2.62492e-05"/>
          <joint name="shoulder" pos="0 0 0" axis="0 0 -1" range="-1.5708 1.5708"/>
          <geom type="mesh" rgba="0.752941 0.752941 0.752941 1" mesh="link2" contype="0" conaffinity="0"/>
          <body name="link3" pos="0.236815 0.0300024 0" quat="0.707107 0 0 0.707107">
            <inertial pos="-0.000762809 -0.11442 -0.000177275" quat="0.672045 0.673543 -0.217394 0.217796" mass="0.123009" diaginertia="0.000104224 0.000103898 1.46353e-05"/>
            <joint name="elbow" pos="0 0 0" axis="0 0 1" range="-1 3.1416"/>
            <geom type="mesh" rgba="0.752941 0.752941 0.752941 1" mesh="link3" contype="0" conaffinity="0"/>
            <body name="gripper_link" pos="0.002906 -0.21599 -0.00066683" quat="0.499998 -0.5 0.500002 -0.5">
              <inertial pos="0.0288857 -0.000776842 -0.000779765" quat="0.526622 0.526622 0.471879 0.471879" mass="0.00365698" diaginertia="2.34478e-06 1.4718e-06 1.13696e-06"/>
              <joint name="hand" pos="0 0 0" axis="0 0 1" range="0 1.5"/>
              <geom type="mesh" rgba="0.219608 0.219608 0.219608 1" mesh="gripper_link" contype="0" conaffinity="0"/>
            </body>
            <site name="hand_tcp" pos="0.002 -0.2802 0" quat="0.5 -0.5 0.5 -0.5" size="0.005" rgba="1 0 0 0.5"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="base_actuator"     joint="base"     kp="200" kv="20" ctrlrange="-3.1416 3.1416"/>
    <position name="shoulder_actuator" joint="shoulder" kp="300" kv="30" ctrlrange="-1.5708 1.5708"/>
    <position name="elbow_actuator"    joint="elbow"    kp="250" kv="25" ctrlrange="-1.0 3.1416"/>
    <position name="hand_actuator"     joint="hand"     kp="100" kv="10" ctrlrange="0 1.5"/>
  </actuator>
</mujoco>
